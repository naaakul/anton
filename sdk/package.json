{
  "name": "Vishlex",
  "version": "0.1.0",
  "description": "Privacy-friendly analytics SDK — bring your own database",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    },
    "./next": {
      "import": "./dist/next.js",
      "require": "./dist/next.cjs",
      "types": "./dist/next.d.ts"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "analytics",
    "nextjs",
    "privacy"
  ],
  "author": "",
  "license": "ISC",
  "peerDependencies": {
    "next": ">=14",
    "react": ">=18",
    "react-dom": ">=18"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": false
    },
    "react-dom": {
      "optional": false
    },
    "next": {
      "optional": false
    }
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/react": "^18.3.28",
    "next": "^15.5.14",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  }
}
